nodes/fragment/216/node = SubResource("VisualShaderNodeExpression_14kdc")
nodes/fragment/216/position = Vector2(3820, 1780)
nodes/fragment/216/size = Vector2(820, 2200)
nodes/fragment/216/input_ports = "0,5,p1;1,5,p2;2,5,p3;3,5,p4;4,5,p5;5,5,p6;6,5,p7;7,5,p8;8,5,p9;9,5,p10;10,5,p11;11,5,p12;12,5,p13;13,5,p14;14,5,p15;15,5,p16;16,5,p17;17,5,p18;18,5,p19;19,5,p20;20,5,p21;21,5,p22;22,5,p23;23,5,p24;24,0,pD;25,0,transD;26,1,tP;27,0,ts;"
nodes/fragment/216/output_ports = "0,5,result;1,0,alpha;"
nodes/fragment/216/expression = "float _peakTotalDurationScaled=ts*(pD + 2.0*transD);
float _h=1.0 + pD/(2.0*transD);
float _totalPatternsScaled=float(tP)*ts*(pD+transD);
vec4 acc=vec4(0.0);
float x=TIME;
vec4 patterns[24] = vec4[24](
p1,p2,p3,p4,p5,p6,p7,p8,
p9,p10,p11,p12,p13,p14,p15,p16,
p17,p18,p19,p20,p21,p22,p23,p24
);

float random=fract(sin(x * 12.9898) * 43758.5453);
int r=int(random * 24.0);
	
for (int i = 0; i < tP; i++) {
	vec4 pattern = patterns[i];
	float dt = float(i)*ts*(pD + transD) - transD*ts;
	float lt = (x-dt)/_peakTotalDurationScaled;
	
	float spike=abs(2.0*(lt - floor(lt + 0.5)))*_h;
	float clampSpike = clamp(spike, 0.0, 1);
	
    float tMod = mod(x-dt,_totalPatternsScaled)/_peakTotalDurationScaled;
	float active=(tMod < 1.0)? 1.0 : 0.0;
	
    float f = clampSpike*active;

    acc += f * pattern;
}

result = acc;
alpha = result.a;"
